# MongoDB connection string
MONGODB_URI=mongodb://localhost:27017/divyup

# NextAuth configuration
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=your-super-secret-key-change-in-production

# GitHub OAuth (optional)
GITHUB_ID=your-github-client-id
GITHUB_SECRET=your-github-client-secret

# Billing links (configure in your payment provider dashboard)
STRIPE_CHECKOUT_LINK=
STRIPE_BILLING_PORTAL_LINK=

# Webhook validation for /api/billing/webhook
BILLING_WEBHOOK_SECRET=change-me

# Optional comma-separated list for platform admin access
ADMIN_EMAILS=
